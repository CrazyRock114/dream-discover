# ============================================
# Dream Discover - 环境变量配置说明
# ============================================

# ----- Railway 后端必填 -----

# 服务端口（Railway 会自动注入 PORT，无需手动设置）
# PORT=9091

# Supabase 配置
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key  # 后端管理用户用

# Resend 邮件配置
RESEND_API_KEY=re_xxxxxxxx
FROM_EMAIL=noreply@dreamdiscover.top

# DeepSeek LLM 配置
DEEPSEEK_API_KEY=your_deepseek_api_key
# DEEPSEEK_BASE_URL=https://api.deepseek.com  # 默认值，通常无需修改
# LLM_MODEL=deepseek-chat  # 默认值，可选 deepseek-reasoner

# ASR 语音识别配置（默认使用 DeepSeek 兼容的 Whisper 端点）
# 如使用 OpenAI Whisper：
# ASR_API_KEY=your_openai_api_key
# ASR_BASE_URL=https://api.openai.com/v1
# ASR_MODEL=whisper-1
# 如使用 DeepSeek（需确认是否支持 audio 端点）：
# ASR_API_KEY=your_deepseek_api_key
# ASR_BASE_URL=https://api.deepseek.com
# ASR_MODEL=whisper-1

# Cloudflare R2 对象存储配置
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
# R2_PUBLIC_URL=https://your-custom-domain.com  # 可选：R2 自定义域名（公开访问，无需签名 URL）

# ----- Vercel 前端必填 -----

# 后端 API 地址（Railway 部署后的 URL）
EXPO_PUBLIC_BACKEND_BASE_URL=https://your-railway-app.up.railway.app
