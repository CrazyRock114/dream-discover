# ============================================
# Dream Discover - 环境变量配置说明
# ============================================

# ----- Railway 后端必填 -----
# 服务端口（Railway 会自动注入 PORT，无需手动设置）
# PORT=9091

# Supabase 数据库配置
COZE_SUPABASE_URL=your_supabase_url
COZE_SUPABASE_ANON_KEY=your_supabase_anon_key

# 对象存储配置
COZE_BUCKET_ENDPOINT_URL=your_s3_endpoint_url
COZE_BUCKET_NAME=your_bucket_name

# Coze 集成平台 API
COZE_INTEGRATION_BASE_URL=https://integration.coze.cn
COZE_INTEGRATION_MODEL_BASE_URL=https://integration.coze.cn/api/v3

# Coze 认证配置（用于 LLM 和 ASR 调用）
COZE_OUTBOUND_AUTH_ENDPOINT=https://integration.coze.cn/api/v1/secret

# ----- Vercel 前端必填 -----
# 后端 API 地址（Railway 部署后的 URL）
EXPO_PUBLIC_BACKEND_BASE_URL=https://your-railway-app.up.railway.app
