{
  "name": "expo-express-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm run dev:server & pnpm run dev:client",
    "dev:server": "cd server && NODE_ENV=development PORT=9091 npx tsx watch ./src/index.ts",
    "dev:client": "cd client && EXPO_PUBLIC_BACKEND_BASE_URL=http://localhost:9091 npx expo start --web --clear",
    "build": "cd server && pnpm run build",
    "start": "cd server && pnpm run start",
    "preinstall": "npx only-allow pnpm",
    "lint:client": "cd client && pnpm run lint",
    "lint:server": "cd server && pnpm run lint",
    "lint:all": "pnpm run lint:client && pnpm run lint:server"
  },
  "dependencies": {},
  "devDependencies": {},
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.27.2"
    },
    "patchedDependencies": {
      "expo@54.0.33": "patches/expo@54.0.33.patch"
    }
  }
}
